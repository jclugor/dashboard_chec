# Runtime
ENVIRONMENT=local
LOG_LEVEL=INFO
DEBUG=false
DATA_BACKEND=pickle
API_TRANSPORT=http

# Dash
HOST=0.0.0.0
PORT=8050

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000
API_RELOAD=false

# Data and output
DATA_DIR=/app/data
OUTPUT_DIR=/tmp/outputs
CACHE_ENABLED=true

# Inference backend selection: mock|local|azure_ml|databricks
MODEL_BACKEND=mock

# Inference networking
REQUEST_TIMEOUT_SECONDS=30
INFERENCE_HTTP_RETRIES=1
INFERENCE_RETRY_BACKOFF_MS=250

# Technical chatbot / RAG assessment placeholders
CHATBOT_ENABLED=false
LLM_PROVIDER=mock
LLM_ENDPOINT_NAME=
LLM_ROUTING_ENABLED=false
LLM_DEFAULT_TIER=medium
LLM_CHEAP_ENDPOINT_NAME=
LLM_MEDIUM_ENDPOINT_NAME=
LLM_BEST_ENDPOINT_NAME=
LLM_ALLOW_BEST_TIER=false
LLM_MAX_EXPENSIVE_CALLS_PER_REQUEST=1
LLM_ROUTE_SIMPLE_TO_CHEAP=true
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2
GEMINI_API_KEY=
GEMINI_MODEL=
CHATBOT_CORPUS_DIR=/app/data/chatbot_corpus
CHATBOT_CORPUS_VOLUME_DIR=
CHATBOT_CORPUS_SUBDIR=chatbot_corpus
CHATBOT_SKILLS_DIR=
CHATBOT_SKILLS_VOLUME_DIR=
CHATBOT_SKILLS_SUBDIR=active
CHATBOT_RETRIEVAL_TOP_K=5
CHATBOT_MAX_CONTEXT_CHARS=12000
RETRIEVER_BACKEND=local_jsonl
AI_SEARCH_ENDPOINT_NAME=chec-agent-search
AI_SEARCH_INDEX_NAME=chec_dbx_demo.gold.technical_doc_chunks_current_index
AI_SEARCH_TOP_K=8
AI_SEARCH_QUERY_TYPE=hybrid
AI_SEARCH_EMBEDDING_ENDPOINT_NAME=databricks-qwen3-embedding-0-6b
AI_SEARCH_ENDPOINT_TYPE=STANDARD

# Payload guardrails
MAX_SUMMARY_POINTS=5000
SUMMARY_INTERPRETABILITY_ENABLED=true
SUMMARY_INTERPRETABILITY_MAX_POINTS=5
SUMMARY_INTERPRETABILITY_HIGH_ROBUST_Z=3.0
SUMMARY_INTERPRETABILITY_LOW_ROBUST_Z=-2.5
SUMMARY_INTERPRETABILITY_DELTA_ROBUST_Z=3.0
SUMMARY_INTERPRETABILITY_TOP_CONTRIBUTOR_PCT=0.10
SUMMARY_INTERPRETABILITY_SUSTAINED_MIN_DAYS=3
SUMMARY_INTERPRETABILITY_INCLUDE_AGENT_TEXT_DEFAULT=true
SUMMARY_INTERPRETABILITY_CACHE_SECONDS=300
MAX_MAP_HTML_CHARS=8000000

# Dash startup behavior for scale-to-zero API cold starts
API_STARTUP_POLL_SECONDS=3
API_KEEPALIVE_SECONDS=60
API_STARTUP_MAX_ATTEMPTS=0

# Databricks (only when MODEL_BACKEND=databricks)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_MODEL_ENDPOINT=

# Databricks SQL app/runtime access (only when DATA_BACKEND=databricks_sql)
DATABRICKS_SQL_WAREHOUSE_ID=
DATABRICKS_SQL_HTTP_PATH=
DATABRICKS_CATALOG_NAME=chec_dbx_demo
DATABRICKS_GOLD_SCHEMA=gold
DATABRICKS_SILVER_SCHEMA=silver

# Azure ML (only when MODEL_BACKEND=azure_ml)
AZURE_ML_ENDPOINT=
AZURE_ML_KEY=

# Worker guidance:
# - keep WEB_CONCURRENCY=1 and UVICORN_WORKERS=1 initially
# - increase only after memory/load baselines are validated
WEB_CONCURRENCY=1
WEB_THREADS=2
UVICORN_WORKERS=1
