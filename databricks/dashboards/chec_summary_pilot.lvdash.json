{
  "datasets": [
    {
      "name": "summary_daily",
      "displayName": "summary_daily",
      "queryLines": [
        "SELECT CAST(fecha_dia AS DATE) AS fecha_dia, COALESCE(circuito, 'Sin circuito') AS circuito, COALESCE(municipio, 'Sin municipio') AS municipio, COALESCE(event_family, 'Sin criterio') AS event_family, COALESCE(saidi_total, 0.0) AS saidi_total, COALESCE(saifi_total, 0.0) AS saifi_total, COALESCE(event_count, 0) AS event_count, COALESCE(users_affected_total, 0.0) AS users_affected_total FROM chec_dbx_demo.gold.gold_saidi_saifi_daily WHERE fecha_dia IS NOT NULL"
      ],
      "catalog": "chec_dbx_demo",
      "schema": "gold"
    }
  ],
