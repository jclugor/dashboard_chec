# Copy to .env.databricks-fresh-install at the repository root before running
# databricks/scripts/fresh_install_databricks.sh. The local .env file is ignored
# by git and can be safely edited per deployer/workspace.

# Azure foundation
AZURE_SUBSCRIPTION_ID="fdc04a72-8109-4807-9dc4-c809f25b6f42"
AZURE_REGION="eastus"
AZURE_RESOURCE_GROUP="rg-chec-dashboard-dev"
DATABRICKS_WORKSPACE_NAME="adb-chec-dashboard-dev"
DATABRICKS_WORKSPACE_ID=""

# Databricks auth and naming
DATABRICKS_HOST="https://adb-7405611288758888.8.azuredatabricks.net"
DATABRICKS_AUTH_TYPE="azure-cli"
CATALOG_NAME="chec_dbx_demo"
APP_CATALOG_NAME="chec_dbx_demo"
APP_NAME="chec-dash-parity"
REVIEWER_PRINCIPAL="users"
EDITOR_PRINCIPAL=""

# Unity Catalog managed storage for fresh metastores without a storage root.
# Leave names blank to derive safe defaults from the discovered workspace ID.
UC_MANAGED_STORAGE_ENABLED="true"
UC_STORAGE_ACCOUNT_NAME=""
UC_STORAGE_CONTAINER_NAME="unity-catalog"
UC_ACCESS_CONNECTOR_NAME=""
UC_STORAGE_CREDENTIAL_NAME="chec_dashboard_mi_cred"
UC_EXTERNAL_LOCATION_NAME="chec_dashboard_uc_root"
CATALOG_MANAGED_LOCATION=""

# Local source data. Defaults assume the repo lives at <CHEC_ROOT>/dashboard.
CHEC_SOURCE_DATA_DIR=""
CHATBOT_SOURCE_DOCS_DIR=""
CHATBOT_VARIABLES_SOURCE_DIR=""
CHATBOT_CORPUS_SOURCE_DIR=""
CHATBOT_SKILLS_SOURCE_DIR=""
BUILD_CHATBOT_CORPUS="true"

# SQL warehouse. Leave APP_WAREHOUSE_ID empty on first run; the installer will
# create/reuse WAREHOUSE_NAME and write the discovered ID back to the local env.
WAREHOUSE_NAME="CHEC Dashboard Warehouse"
APP_WAREHOUSE_ID=""
DATABRICKS_SQL_WAREHOUSE_ID=""
WAREHOUSE_CLUSTER_SIZE="Small"
WAREHOUSE_AUTO_STOP_MINS="10"
WAREHOUSE_TYPE="PRO"
WAREHOUSE_ENABLE_SERVERLESS="true"
WAREHOUSE_ENABLE_PHOTON="true"
GRANT_APP_WAREHOUSE_ACCESS="true"

# Bundle/data settings
SOURCE_VOLUME_NAME="source_files"
ARTIFACT_VOLUME_NAME="artifacts"
USE_CLASSIC_JOBS="false"
CHECK_CLASSIC_SKU_FALLBACKS="false"
FRESH_INSTALL_RESET_STALE_BUNDLE_STATE="true"

# App runtime settings
APP_GOLD_SCHEMA="gold"
APP_SILVER_SCHEMA="silver"
APP_SOURCE_VOLUME_NAME="source_files"
APP_COMPUTE_SIZE="MEDIUM"

# UITI impact time-series interpretability
APP_SUMMARY_INTERPRETABILITY_ENABLED="true"
APP_SUMMARY_INTERPRETABILITY_MAX_POINTS="5"
APP_SUMMARY_INTERPRETABILITY_HIGH_ROBUST_Z="3.0"
APP_SUMMARY_INTERPRETABILITY_LOW_ROBUST_Z="-2.5"
APP_SUMMARY_INTERPRETABILITY_DELTA_ROBUST_Z="3.0"
APP_SUMMARY_INTERPRETABILITY_TOP_CONTRIBUTOR_PCT="0.10"
APP_SUMMARY_INTERPRETABILITY_SUSTAINED_MIN_DAYS="3"
APP_SUMMARY_INTERPRETABILITY_INCLUDE_AGENT_TEXT_DEFAULT="true"
APP_SUMMARY_INTERPRETABILITY_CACHE_SECONDS="300"

# Chatbot/RAG runtime
APP_CHATBOT_ENABLED="true"
APP_CHATBOT_CONVERSATION_BACKEND="databricks_sql"
APP_CHATBOT_CONVERSATION_SCHEMA="agent"
APP_CHATBOT_CONTEXT_TOOLS_SCHEMA="agent_tools"
APP_CHATBOT_MEMORY_MAX_TURNS="8"
APP_RETRIEVER_BACKEND="databricks_ai_search"
APP_AI_SEARCH_ENDPOINT_NAME="chec-agent-search"
APP_AI_SEARCH_INDEX_FULL_NAME="chec_dbx_demo.gold.technical_doc_chunks_current_index"
APP_AI_SEARCH_INDEX_RESOURCE_KEY="chatbot_ai_search_index"
APP_AI_SEARCH_TOP_K="8"
APP_AI_SEARCH_QUERY_TYPE="hybrid"
APP_AI_SEARCH_EMBEDDING_ENDPOINT_NAME="databricks-qwen3-embedding-0-6b"
APP_AI_SEARCH_ENDPOINT_TYPE="STANDARD"
APP_LLM_PROVIDER="databricks_model_serving"
APP_LLM_ENDPOINT_NAME="databricks-qwen3-next-80b-a3b-instruct"
APP_LLM_ENDPOINT_RESOURCE_KEY="chatbot_llm_endpoint"
APP_LLM_MAX_TOKENS="1200"
APP_LLM_TEMPERATURE="0.2"

# Observability/evaluation
APP_CHATBOT_OBSERVABILITY_ENABLED="true"
APP_CHATBOT_TELEMETRY_SCHEMA="agent_observability"
APP_CHATBOT_EVAL_REPORT_ONLY="true"
APP_CHATBOT_EVAL_LLM_JUDGES_ENABLED="false"
APP_CHATBOT_EVAL_ENFORCE="false"
APP_MLFLOW_TRACKING_URI="databricks"
APP_MLFLOW_EXPERIMENT_NAME="/Shared/chec_dash_parity/agent_observability"
APP_MLFLOW_PROMPT_NAME="chec_chatbot_answer_prompt"
APP_MLFLOW_PROMPT_ALIAS="production"

# Gemini is opt-in. Leave these blank unless the workspace has a secret scope
# and the app should receive a GEMINI_API_KEY valueFrom resource.
APP_GEMINI_SECRET_RESOURCE_KEY=""
APP_GEMINI_SECRET_SCOPE=""
APP_GEMINI_SECRET_KEY=""

# Orchestrator controls
FRESH_INSTALL_STAGE="all"
FRESH_INSTALL_ENV_FILE=".env.databricks-fresh-install"
FRESH_INSTALL_SKIP_PREFLIGHT="false"
